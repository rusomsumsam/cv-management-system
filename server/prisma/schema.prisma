generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

model User {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String
  email        String  @unique
  password     String
  profilePhoto String?
  location     String?
  role         Role    @default(CANDIDATE)

  projects       Project[]
  positions      Position[]
  userAttributes UserAttribute[]
  cvs            CV[]
  discussions    Discussion[]
  likes          Like[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String  @id @default(cuid())
  title       String
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  DROPDOWN
}

model Attribute {
  id String @id @default(cuid())

  name String @unique

  category String

  type AttributeType

  userAttributes     UserAttribute[]
  positionAttributes PositionAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  id          String   @id @default(cuid())

  title       String
  description String?

  company     String?
  location    String?
  department  String?
  deadline    DateTime?

  isActive    Boolean @default(true)

  userId String
  user   User @relation(fields: [userId], references: [id])

  positionAttributes PositionAttribute[]
  cvs                CV[]
  discussions        Discussion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model UserAttribute {
  id String @id @default(cuid())

  userId      String
  attributeId String

  value String?

  user      User      @relation(fields: [userId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, attributeId])
}

model PositionAttribute {
  id String @id @default(cuid())

  positionId  String
  attributeId String

  position  Position  @relation(fields: [positionId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  createdAt DateTime @default(now())
}

enum CVStatus {
  DRAFT
  PUBLISHED
}

model CV {
  id String @id @default(cuid())

  fullName  String
  email     String
  phone     String?

  summary    String?
  skills     String?
  education  String?
  experience String?
  projects   String?

  status CVStatus @default(DRAFT)

  userId     String
  positionId String

  user     User     @relation(fields: [userId], references: [id])
  position Position @relation(fields: [positionId], references: [id])

  likes Like[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Discussion {
  id String @id @default(cuid())

  content String

  userId     String
  positionId String

  user     User     @relation(fields: [userId], references: [id])
  position Position @relation(fields: [positionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id String @id @default(cuid())

  userId String
  cvId   String

  user User @relation(fields: [userId], references: [id])
  cv   CV   @relation(fields: [cvId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, cvId])
}
