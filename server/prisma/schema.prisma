generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

model User {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String
  email        String  @unique
  password     String
  profilePhoto String?
  location     String?
  role         Role    @default(CANDIDATE)

  projects       Project[]
  positions      Position[]
  userAttributes UserAttribute[]
  cvs            CV[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String  @id @default(cuid())
  title       String
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attribute {
  id   String @id @default(cuid())
  name String
  type String

  userAttributes     UserAttribute[]
  positionAttributes PositionAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  id          String  @id @default(cuid())
  title       String
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  positionAttributes PositionAttribute[]
  cvs                CV[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAttribute {
  id String @id @default(cuid())

  userId      String
  attributeId String

  user      User      @relation(fields: [userId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  createdAt DateTime @default(now())
}

model PositionAttribute {
  id String @id @default(cuid())

  positionId  String
  attributeId String

  position  Position  @relation(fields: [positionId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  createdAt DateTime @default(now())
}

enum CVStatus {
  DRAFT
  PUBLISHED
}

model CV {
  id String @id @default(cuid())

  userId     String
  positionId String

  status CVStatus @default(DRAFT)

  user     User     @relation(fields: [userId], references: [id])
  position Position @relation(fields: [positionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
