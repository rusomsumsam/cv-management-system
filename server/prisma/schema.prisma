generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

model User {
  id           String  @id @default(cuid())
  firstName    String
  lastName     String
  email        String  @unique
  password     String
  profilePhoto String?
  location     String?
  role         Role    @default(CANDIDATE)

  projects       Project[]
  positions      Position[]
  userAttributes UserAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String  @id @default(cuid())
  title       String
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attribute {
  id   String @id @default(cuid())
  name String
  type String

  userAttributes UserAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Position {
  id          String  @id @default(cuid())
  title       String
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAttribute {
  id String @id @default(cuid())

  userId      String
  attributeId String

  user      User      @relation(fields: [userId], references: [id])
  attribute Attribute @relation(fields: [attributeId], references: [id])

  createdAt DateTime @default(now())
}
